{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MLX Pilot",
  "version": "0.1.0",
  "identifier": "com.kaike.mlxollamapilot",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MLX Pilot — Orbital Command",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../../scripts/mlx_airllm_bridge.py": "mlx_airllm_bridge.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
